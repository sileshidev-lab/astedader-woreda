generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  WOREDA_ADMIN
  HIBRET_ADMIN
  MEMBER
}

enum AccountStatus {
  ACTIVE
  DISABLED
  PENDING_SETUP
}

enum AnnouncementType {
  meeting
  conference
  trend_report
  other
}

enum AnnouncementStatus {
  draft
  published
  closed
}

enum ReportStatus {
  draft
  submitted
  approved
  rejected
  changes_requested
}

enum ReviewDecision {
  approved
  rejected
  changes_requested
}

enum AttendanceStatus {
  present
  absent
  excused
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String?
  role         UserRole
  status       AccountStatus @default(PENDING_SETUP)
  privileges   String[]      @default([])

  hibretId String?
  memberId String? @unique

  setupToken String?
  resetToken String?
  resetTokenExpiresAt DateTime?

  twoFactorEnabled Boolean @default(false)
  twoFactorLoginToken String?
  twoFactorLoginExpiresAt DateTime?
  twoFactorCodeHash String?
  twoFactorCodeExpiresAt DateTime?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hibret             Hibret?            @relation(fields: [hibretId], references: [id])
  member             Member?            @relation(fields: [memberId], references: [id])
  recordedAttendance AttendanceRecord[] @relation("AttendanceRecordedBy")

  @@index([role])
  @@index([status])
  @@index([hibretId])
  @@index([resetToken])
  @@index([twoFactorLoginToken])
}

model Hibret {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  status      String? @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  families Family[]
  members  Member[]

  announcementTargets AnnouncementTarget[]
  reports             HibretReport[]
  attendanceRecords   AttendanceRecord[]

  @@index([name])
}

model Family {
  id          String  @id @default(cuid())
  name        String
  hibretId    String
  contactName String?
  phone       String?
  status      String? @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hibret  Hibret   @relation(fields: [hibretId], references: [id])
  members Member[]

  @@index([hibretId])
  @@index([name])
}

model Member {
  id         String  @id @default(cuid())
  memberCode String? @unique
  fanId      String? @unique
  ppId       String? @unique

  firstName       String
  fatherName      String
  grandfatherName String?
  gender          String

  dateOfBirth DateTime?
  phone       String?
  email       String?

  hibretId String
  familyId String?

  membershipStatus String?
  registrationType String?
  membershipYear   Int?
  partyRole        String?

  educationLevel      String?
  fieldOfStudy        String?
  workplace           String?
  workType            String?
  workExperienceYears Int?

  zone         String?
  kebele       String?
  ethnicity    String?
  healthStatus String?

  photoFileId       String?
  profileCompletion Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hibret            Hibret             @relation(fields: [hibretId], references: [id])
  family            Family?            @relation(fields: [familyId], references: [id])
  user              User?
  attendanceRecords AttendanceRecord[]

  @@index([hibretId])
  @@index([familyId])
  @@index([gender])
  @@index([membershipStatus])
}

model AttendanceRecord {
  id String @id @default(cuid())

  announcementId String
  hibretId       String
  memberId       String

  status       AttendanceStatus
  note         String?
  recordedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  hibret       Hibret       @relation(fields: [hibretId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  recordedBy   User?        @relation("AttendanceRecordedBy", fields: [recordedById], references: [id])

  @@unique([announcementId, hibretId, memberId])
  @@index([announcementId])
  @@index([hibretId])
  @@index([memberId])
  @@index([status])
}

model ActivityLog {
  id          String  @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  operation   String
  targetType  String?
  targetName  String?
  description String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([actorUserId])
  @@index([actorEmail])
  @@index([actorRole])
  @@index([operation])
  @@index([createdAt])
}

model Announcement {
  id                 String             @id @default(cuid())
  title              String
  type               AnnouncementType
  instructions       String
  status             AnnouncementStatus @default(draft)
  deadline           DateTime?
  attendanceRequired Boolean            @default(false)

  createdByUserId String?
  publishedAt     DateTime?
  closedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targets           AnnouncementTarget[]
  attachments       AnnouncementAttachment[]
  reports           HibretReport[]
  attendanceRecords AttendanceRecord[]

  @@index([type])
  @@index([status])
  @@index([deadline])
  @@index([createdAt])
}

model AnnouncementTarget {
  id             String @id @default(cuid())
  announcementId String
  hibretId       String

  createdAt DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  hibret       Hibret       @relation(fields: [hibretId], references: [id], onDelete: Cascade)

  @@unique([announcementId, hibretId])
  @@index([announcementId])
  @@index([hibretId])
}

model FileRecord {
  id           String  @id @default(cuid())
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  path         String
  category     String?
  uploadedById String?

  createdAt DateTime @default(now())

  announcementAttachments AnnouncementAttachment[]
  reportAttachments       ReportAttachment[]
  broadcastAttachments    BroadcastAttachment[]
  resources               Resource[]

  @@index([category])
  @@index([uploadedById])
  @@index([createdAt])
}

model AnnouncementAttachment {
  id             String @id @default(cuid())
  announcementId String
  fileId         String

  createdAt DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  file         FileRecord   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([fileId])
}

model HibretReport {
  id             String @id @default(cuid())
  announcementId String
  hibretId       String

  title   String
  summary String?
  body    String
  status  ReportStatus @default(draft)

  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  reviewDecision ReviewDecision?
  reviewComment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  announcement Announcement       @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  hibret       Hibret             @relation(fields: [hibretId], references: [id], onDelete: Cascade)
  attachments  ReportAttachment[]
  reviews      ReportReview[]

  @@unique([announcementId, hibretId])
  @@index([announcementId])
  @@index([hibretId])
  @@index([status])
  @@index([reviewDecision])
}

model ReportAttachment {
  id       String @id @default(cuid())
  reportId String
  fileId   String

  createdAt DateTime @default(now())

  report HibretReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  file   FileRecord   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([fileId])
}

model ReportReview {
  id             String         @id @default(cuid())
  reportId       String
  reviewerUserId String?
  decision       ReviewDecision
  comment        String?

  createdAt DateTime @default(now())

  report HibretReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([decision])
  @@index([createdAt])
}

model Broadcast {
  id              String   @id @default(cuid())
  title           String
  summary         String?
  bodyHtml        String
  status          String   @default("draft")
  coverFileId     String?
  targetRoles     String[] @default(["HIBRET_ADMIN", "MEMBER"])
  createdByUserId String?

  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  attachments BroadcastAttachment[]

  @@index([status])
  @@index([createdAt])
}

model BroadcastAttachment {
  id          String @id @default(cuid())
  broadcastId String
  fileId      String

  createdAt DateTime @default(now())

  broadcast Broadcast  @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  file      FileRecord @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([fileId])
}

model Resource {
  id              String   @id @default(cuid())
  title           String
  description     String?
  status          String   @default("draft")
  category        String?
  fileId          String?
  targetRoles     String[] @default(["HIBRET_ADMIN", "MEMBER"])
  createdByUserId String?

  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  file FileRecord? @relation(fields: [fileId], references: [id])

  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ChatConversation {
  id                String   @id @default(cuid())
  subject           String
  participantEmails String[] @default([])
  createdByUserId   String?
  createdByEmail    String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  messages ChatMessage[]

  @@index([createdAt])
  @@index([updatedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderUserId   String?
  senderEmail    String
  body           String
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  ChatAttachment[]

  @@index([conversationId])
  @@index([createdAt])
}

model ChatAttachment {
  id           String   @id @default(cuid())
  messageId    String
  originalName String
  storedName   String
  mimeType     String
  sizeBytes    Int
  path         String
  createdAt    DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}


model Notification {
  id                String   @id @default(cuid())
  title             String
  message           String?
  type              String
  link              String?
  recipientRole     String?
  recipientUserId   String?
  recipientHibretId String?
  readByUserIds     String[] @default([])
  createdByUserId   String?
  createdAt         DateTime @default(now())

  @@index([recipientRole])
  @@index([recipientUserId])
  @@index([recipientHibretId])
  @@index([type])
  @@index([createdAt])
}
